              "});",
              "const data = pm.response.json();",
              "pm.test(\"Devuelve token\", function () {",
              "    pm.expect(data.accessToken || data.token).to.exist;",
              "});",
              "if (data.accessToken) {",
              "    pm.collectionVariables.set(\"token\", data.accessToken);",
              "} else if (data.token) {",
              "    pm.collectionVariables.set(\"token\", data.token);",
