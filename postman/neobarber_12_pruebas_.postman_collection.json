    {
      "name": "010 GET /api/barbers (prepara barberUserId)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Listar barberos responde 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "const data = pm.response.json();",
              "pm.test(\"La respuesta es un arreglo\", function () {",
              "    pm.expect(data).to.be.an(\"array\");",
              "});",
              "if (data.length > 0) {",
              "    const first = data[0];",
              "    const barberId = first?.userId?._id || first?.user?._id || first?.user?.id || first?.userId || first?._id;",
              "    if (barberId) {",
              "        pm.collectionVariables.set(\"barberUserId\", barberId);",
              "    }",
              "}",
              "pm.test(\"barberUserId quedó cargado\", function () {",
              "    pm.expect(pm.collectionVariables.get(\"barberUserId\")).to.not.be.empty;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/barbers",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "barbers"
          ]
        },
        "description": "Obtiene barberos y guarda barberUserId antes de crear la cita."
      },
